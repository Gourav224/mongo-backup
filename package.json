{
  "name": "mongo-backup",
  "version": "1.0.0",
  "description": "MongoDB backup & restore CLI with S3, dry-run, checksums, retention",
  "type": "module",
  "bin": {
    "mgback": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "backup": "bun run src/index.ts backup",
    "restore": "bun run src/index.ts restore",
    "list": "bun run src/index.ts list",
    "typecheck": "bun run tsc --noEmit"
  },
  "dependencies": {
    "cli-progress": "latest",
    "kleur": "latest",
    "mongodb": "6.9.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cli-progress": "^3.11.6"
  }
}
